<Window x:Class="TiclyMusic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticly Music" Height="550" Width="450" Background="#e9e9e9"
        WindowStyle="None" AllowsTransparency="True" KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="18" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="12">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="5" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#565656" />
        </Style>
        <Style x:Key="RoundedListBoxStyle" TargetType="ListBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="12">
                            <ScrollViewer Margin="0" Focusable="false">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="5" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#565656" />
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Custom Title Bar -->
        <DockPanel Background="#e9e9e9" Height="40" VerticalAlignment="Top" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                <!-- Close Button -->
                <Button Width="15" Height="15" Background="Red" BorderBrush="Transparent" 
                        Click="CloseButton_Click" Margin="5,0,0,0" ToolTip="Close"
                        Style="{StaticResource RoundedButtonStyle}" />
                <!-- Minimize Button -->
                <Button Width="15" Height="15" Background="#febb38" BorderBrush="Transparent" 
                        Click="MinimizeButton_Click" Margin="5,0,0,0" ToolTip="Minimize"
                        Style="{StaticResource RoundedButtonStyle}" />
                <!-- Full Screen Button -->
                <Button Width="15" Height="15" Background="#33c843" BorderBrush="Transparent" 
                        Click="FullScreenButton_Click" Margin="5,0,0,0" ToolTip="Maximize/Restore"
                        Style="{StaticResource RoundedButtonStyle}" />
            </StackPanel>
            <TextBlock Text="Ticly Music" VerticalAlignment="Center" HorizontalAlignment="Center" 
                      FontSize="14" FontWeight="SemiBold" Foreground="#565656" />
            <Button Content="⚙" Width="20" Height="20" Background="Transparent" BorderBrush="Transparent"
                   Click="SettingsButton_Click" ToolTip="Settings" FontSize="12"
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" />
        </DockPanel>

        <!-- Main Content -->
        <StackPanel Margin="10,50,10,10" VerticalAlignment="Center">
            <!-- Search Section -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBox x:Name="SearchTextBox" Width="300" Height="36" ToolTip="Search for a song..." 
                         FontSize="14" Padding="5" Background="#f8f8f8" Foreground="#565656" 
                         Style="{StaticResource RoundedTextBoxStyle}" KeyDown="SearchTextBox_KeyDown" />
                <Button Content="✕" Width="36" Height="36" Click="ClearSearchButton_Click" 
                        Background="#F44336" Foreground="White" FontSize="16" Margin="10,0,0,0"
                        Style="{StaticResource RoundedButtonStyle}" ToolTip="Clear search" />
            </StackPanel>

            <Button Content="Search" Width="120" Height="36" Click="SearchButton_Click" 
                    HorizontalAlignment="Center" Background="#4CAF50" Foreground="White" FontSize="14"
                    Style="{StaticResource RoundedButtonStyle}" />

            <!-- Results Section -->
            <ListBox x:Name="ResultsListBox" Height="200" Margin="0,10,0,0"
                     SelectionChanged="ResultsListBox_SelectionChanged" FontSize="14"
                     Style="{StaticResource RoundedListBoxStyle}" />

            <!-- Media Player Section -->
            <MediaElement x:Name="MediaElementPlayer" Height="50" LoadedBehavior="Manual" UnloadedBehavior="Stop" />

            <!-- Progress Bar and Time -->
            <Slider x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0" 
                    Height="20" Margin="0,10,0,0" 
                    ValueChanged="ProgressBar_ValueChanged" />
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Center">
                <TextBlock x:Name="ElapsedTimeText" Text="00:00" Width="50" FontSize="12" Foreground="#565656" />
                <TextBlock Text=" / " FontSize="12" Foreground="#565656" />
                <TextBlock x:Name="RemainingTimeText" Text="00:00" Width="50" FontSize="12" Foreground="#565656" />
            </StackPanel>

            <!-- Volume Controls -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0" HorizontalAlignment="Center">
                <TextBlock Text="Volume:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" Foreground="#565656" />
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="0.5" 
                        Width="150" ValueChanged="VolumeSlider_ValueChanged" />
                <TextBlock x:Name="VolumePercentageText" Text="50%" VerticalAlignment="Center" 
                          Margin="5,0,0,0" FontSize="12" Foreground="#565656" Width="35" />
            </StackPanel>

            <!-- Playback Controls -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                <Button x:Name="PlayButton" Content="▶ Play" Width="80" Height="36" Click="PlayButton_Click" 
                        Background="#4CAF50" Foreground="White" FontSize="12"
                        Style="{StaticResource RoundedButtonStyle}" />
                <Button x:Name="PauseButton" Content="⏸ Pause" Width="80" Height="36" Margin="10,0,0,0" Click="PauseButton_Click" 
                        Background="#FF9800" Foreground="White" FontSize="12"
                        Style="{StaticResource RoundedButtonStyle}" />
                <Button x:Name="StopButton" Content="⏹ Stop" Width="80" Height="36" Margin="10,0,0,0" Click="StopButton_Click" 
                        Background="#F44336" Foreground="White" FontSize="12"
                        Style="{StaticResource RoundedButtonStyle}" />
                <Button x:Name="LoopButton" Content="🔁 Loop" Width="80" Height="36" Margin="10,0,0,0" Click="LoopButton_Click" 
                        Background="#e9e9e9" Foreground="#565656" FontSize="12"
                        Style="{StaticResource RoundedButtonStyle}" />
            </StackPanel>

            <!-- Help Text -->
            <TextBlock Text="Shortcuts: Space=Play/Pause, Ctrl+S=Stop, Ctrl+L=Loop, Ctrl+F=Search, Ctrl+,=Settings" 
                      FontSize="9" Foreground="#888" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
